# Application
APP_ENV=development
DEBUG=false

# Seguridad: genere con: uv run python scripts/generate_keys.py
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
SECRET_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/secureauth

# Redis
REDIS_URL=redis://localhost:6379/0

# OAuth2 Providers (Task 14-15)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
