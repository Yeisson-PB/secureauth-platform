# ─────────────────────────────────────────────────────────────────────────────
# SecureAuth Platform — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
# APP_ENV options: development | test | production

DEBUG=false
# WARNING: DEBUG=true in production is automatically overridden to false

APP_VERSION=0.1.0
BASE_URL=http://localhost:8000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: uv run python scripts/generate_keys.py
# Then paste the contents here (replace newlines with \n)

JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret-of-at-least-32-characters

# JWT expiry settings
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=secureauth

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/secureauth

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispassword
REDIS_URL=redis://:redispassword@localhost:6379/0

# Blacklist TTL must match JWT_ACCESS_TOKEN_EXPIRE_MINUTES (in seconds)
REDIS_BLACKLIST_TTL_SECONDS=900

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Brute force protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=900

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array or comma-separated list
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── OAuth2 — Google ───────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ── OAuth2 — GitHub ───────────────────────────────────────────────────────────
# Get from: https://github.com/settings/developers
# Leave empty to disable GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# ── MFA ───────────────────────────────────────────────────────────────────────
MFA_ISSUER_NAME=SecureAuth
MFA_RECOVERY_CODES_COUNT=10

# ── Email (optional — for password reset) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME=SecureAuth Platform
EMAILS_FROM_ADDRESS=noreply@secureauth.dev
